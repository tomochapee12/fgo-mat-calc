{
  "name": "fgo-material-sim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "tsx scripts/generate-seo-files.ts && tsc -b && react-router build && tsx scripts/verify-seo.ts",
    "seo:generate": "tsx scripts/generate-seo-files.ts",
    "seo:verify": "tsx scripts/verify-seo.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && npm test && npm run build",
    "preview": "vite preview --outDir dist/client",
    "data:init": "tsx scripts/initial-fetch.ts",
    "data:update": "tsx scripts/incremental-update.ts",
    "data:quests": "tsx scripts/fetch-free-quests.ts",
    "data:class-boards": "tsx scripts/fetch-class-boards.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "isbot": "^5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^8.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "^8.2.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.10"
  }
}
